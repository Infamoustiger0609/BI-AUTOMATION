# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Power BI Service (optional for later phases)
POWER_BI_CLIENT_ID=your_client_id
POWER_BI_CLIENT_SECRET=your_client_secret
POWER_BI_TENANT_ID=your_tenant_id

# Application Settings
APP_NAME=Prompt2PBI
APP_VERSION=1.0.0
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=./output/logs
LOG_FILE=prompt2pbi.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./output
SAMPLE_DATA_DIR=./data/sample_data
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=[".csv", ".xlsx", ".xls", ".json"]
CORS_ORIGINS=["*"]
REDIS_URL=redis://localhost:6379/0
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_CACHE_TTL_SECONDS=3600
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=120
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
JOB_TIMEOUT_SECONDS=120
APP_API_KEY=optional_internal_api_key
